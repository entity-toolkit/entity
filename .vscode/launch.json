{
  "configurations": [
    {
      "name": "(lldb) Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceRoot}/bin/ntt.exec",
      "args": [
        "-input",
        "../ntt/inputs/ntt_boris_unit.toml"
      ],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "lldb",
      "env": {
        "OMP_PROC_BIND": "spread",
        "OMP_NUM_THREADS": "8"
      },
      "console": "integratedTerminal",
      "preLaunchTask": "ntt"
    }
  ]
}